<?xml version="1.0"?>
<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
  <Script file="ExportImportDialogUI.lua"/>
  <Frame name="SoundtrackExportImportFrame" parent="UIParent" movable="true" enableMouse="true"
         frameStrata="DIALOG" inherits="BackdropTemplate" hidden="true">
    <Size>
      <AbsDimension x="500" y="385"/>
    </Size>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Scripts>
      <OnLoad>
        SoundtrackTheme.ApplyDialogBackdrop(self)
        self:RegisterForDrag("LeftButton")
        self:SetScript("OnDragStart", self.StartMoving)
        self:SetScript("OnDragStop",  self.StopMovingOrSizing)
      </OnLoad>
    </Scripts>
    <Layers>
      <Layer level="OVERLAY">
        <FontString name="SoundtrackExportImportTitle" inherits="GameFontHighlight"
                    text="Export / Import Profile">
          <Anchors>
            <Anchor point="TOP">
              <Offset><AbsDimension x="0" y="-18"/></Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <FontString name="SoundtrackExportImportInstructions" inherits="GameFontHighlightSmall"
                    text="To export: click Select All then Ctrl-C.   To import: paste text, enter a new profile name, then click Import.">
          <Size><AbsDimension x="460" y="0"/></Size>
          <Anchors>
            <Anchor point="TOP">
              <Offset><AbsDimension x="0" y="-42"/></Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Frames>
      <!-- Scrollable text area using Blizzard's InputScrollFrameTemplate,
           the same pattern ChatCopyPaste uses for its copy window. -->
      <ScrollFrame name="SoundtrackExportImportScrollFrame" inherits="InputScrollFrameTemplate">
        <Size>
          <AbsDimension x="458" y="210"/>
        </Size>
        <Anchors>
          <Anchor point="TOP">
            <Offset><AbsDimension x="0" y="-68"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnLoad>
            if self.CharCount then self.CharCount:Hide() end
            self.EditBox:SetFontObject(ChatFontNormal)
            self.EditBox:SetMaxLetters(500000)
            self.EditBox:SetAutoFocus(false)
            -- Use a very large width to prevent word-wrap. Share strings have no
            -- spaces so wrapping at ~442px would force WoW to compute thousands
            -- of line-break positions on paste, freezing the client.
            self.EditBox:SetWidth(10000)
            -- Strip the OnTextChanged handler that InputScrollFrameTemplate wires
            -- up for cursor-tracking scrolling. That behaviour is not needed in a
            -- paste/copy dialog and adds unnecessary overhead.
            self.EditBox:SetScript("OnTextChanged", nil)
          </OnLoad>
        </Scripts>
      </ScrollFrame>
      <!-- Profile name row (used when importing) -->
      <Frame name="SoundtrackExportImportProfileNameRow">
        <Size><AbsDimension x="440" y="22"/></Size>
        <Anchors>
          <Anchor point="BOTTOMLEFT">
            <Offset><AbsDimension x="20" y="58"/></Offset>
          </Anchor>
        </Anchors>
        <Layers>
          <Layer level="ARTWORK">
            <FontString name="SoundtrackExportImportProfileNameLabel" inherits="GameFontHighlightSmall"
                        text="New Profile Name:">
              <Anchors>
                <Anchor point="LEFT"/>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Frames>
          <EditBox name="SoundtrackExportImportProfileNameEditBox"
                   inherits="SoundtrackFrame_EditBoxTemplate" autoFocus="false" letters="128">
            <Size><AbsDimension x="200" y="22"/></Size>
            <Anchors>
              <Anchor point="LEFT" relativePoint="RIGHT"
                      relativeTo="SoundtrackExportImportProfileNameLabel">
                <Offset><AbsDimension x="6" y="0"/></Offset>
              </Anchor>
            </Anchors>
          </EditBox>
        </Frames>
      </Frame>
      <!-- Buttons -->
      <Button name="SoundtrackExportImportCopyButton" inherits="SoundtrackButtonTemplate"
              text="Select All">
        <Size><AbsDimension x="100" y="22"/></Size>
        <Anchors>
          <Anchor point="BOTTOMLEFT">
            <Offset><AbsDimension x="20" y="20"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>Soundtrack.ExportImportDialog.Copy()</OnClick>
          <OnEnter>Soundtrack.ShowTip(self, "Select All", "Selects all export text. Press Ctrl-C to copy to clipboard.")</OnEnter>
          <OnLeave>Soundtrack.HideTip()</OnLeave>
        </Scripts>
      </Button>
      <Button name="SoundtrackExportImportImportButton" inherits="SoundtrackButtonTemplate"
              text="Import">
        <Size><AbsDimension x="100" y="22"/></Size>
        <Anchors>
          <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMRIGHT"
                  relativeTo="SoundtrackExportImportCopyButton">
            <Offset><AbsDimension x="5" y="0"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>Soundtrack.ExportImportDialog.Import()</OnClick>
          <OnEnter>Soundtrack.ShowTip(self, "Import", "Paste an exported profile string into the box above, then click Import.")</OnEnter>
          <OnLeave>Soundtrack.HideTip()</OnLeave>
        </Scripts>
      </Button>
      <Button name="SoundtrackExportImportCloseButton" inherits="UIPanelCloseButton">
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset><AbsDimension x="-5" y="-5"/></Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>Soundtrack.ExportImportDialog.Close()</OnClick>
        </Scripts>
      </Button>
    </Frames>
  </Frame>
</Ui>
