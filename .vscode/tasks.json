{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Unit Tests",
            "type": "shell",
            "command": "python3",
            "args": [
                "scripts/test.py"
            ],
            "windows": {
                "command": "python",
                "args": [
                    "scripts/test.py"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Generate HTML Coverage Report",
            "type": "shell",
            "command": "python3",
            "args": [
                "scripts/coverage.py"
            ],
            "windows": {
                "command": "python",
                "args": [
